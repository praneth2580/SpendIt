# Copy to keystore.properties after running: npm run cap:android:keystore
# Or create manually — do not commit keystore.properties or *.keystore
#
# Reuse on another computer:
#   npm run cap:android:keystore:export   # copy folder to USB / cloud
#   npm run cap:android:keystore:import -- ./spendt-keystore-backup
#
# Same keystore = same app signing identity (required for Play Store updates).

storeFile=spendt-release.keystore
storePassword=YOUR_STORE_PASSWORD
keyAlias=spendt
keyPassword=YOUR_KEY_PASSWORD
