{
  "name": "spendt",
  "private": true,
  "version": "0.0.0",
  "homepage": "https://praneth2580.github.io/SpendIt",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:ghpages": "tsc -b && vite build --mode ghpages",
    "predeploy": "npm run build:ghpages && node scripts/prepare-gh-pages.mjs",
    "deploy": "gh-pages -d dist",
    "lint": "eslint .",
    "preview": "vite preview",
    "cap:sync": "npm run build && bash scripts/cap.sh sync",
    "cap:android": "npm run cap:sync && bash scripts/android-cli.sh run",
    "cap:android:apk": "npm run cap:sync && bash scripts/android-cli.sh build",
    "cap:android:install": "bash scripts/android-cli.sh install",
    "cap:android:devices": "bash scripts/android-cli.sh devices",
    "cap:ios": "bash scripts/cap.sh run ios",
    "cap:run:android": "npm run cap:android",
    "cap:run:ios": "npm run cap:sync && bash scripts/cap.sh run ios"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.4",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@reduxjs/toolkit": "^2.12.0",
    "axios": "^1.15.2",
    "clsx": "^2.1.1",
    "idb": "^8.0.3",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-redux": "^9.3.0",
    "react-router-dom": "^7.14.2",
    "tailwind-merge": "^3.5.0",
    "uuid": "^14.0.0",
    "vite-plugin-pwa": "^1.2.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.5.0",
    "postcss": "^8.5.12",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
